{
  "id": "tpl-5-phase-debate",
  "name": "5-Phase Structured Debate",
  "description": "A comprehensive multi-phase debate workflow with five consecutive phases: Problem Framing, Position Building, Stress Testing, Integration, and Closure. Uses 15 specialized agent bundles in structured phase containers.",
  "category": "system",
  "tags": [
    "multi-phase",
    "structured",
    "debate",
    "5-phase",
    "advanced"
  ],
