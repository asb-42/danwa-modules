      {"id": "e8", "source": "steel-manner-2", "target": "devils-advocate-3", "type": "sequential", "label": "Phase 2→3"},
      {"id": "e9", "source": "devils-advocate-3", "target": "fact-checker-3", "type": "sequential"},
      {"id": "e10", "source": "fact-checker-3", "target": "troll-3", "type": "sequential"},
      {"id": "e11", "source": "troll-3", "target": "mediator-4", "type": "sequential", "label": "Phase 3→4"},
      {"id": "e12", "source": "mediator-4", "target": "ethicist-4", "type": "sequential"},
      {"id": "e13", "source": "ethicist-4", "target": "synthesizer-4", "type": "sequential"},
      {"id": "e14", "source": "synthesizer-4", "target": "moderator-5", "type": "sequential", "label": "Phase 4→5"},
      {"id": "e15", "source": "moderator-5", "target": "critic-5", "type": "sequential"},
      {"id": "e16", "source": "critic-5", "target": "optimizer-5", "type": "sequential"},
      {"id": "e17", "source": "optimizer-5", "target": "gate-1", "type": "sequential"},
      {"id": "e18", "source": "gate-1", "target": "output-1", "type": "conditional", "condition": "consensus_reached"},
      {"id": "e19", "source": "gate-1", "target": "init-1", "type": "feedback", "label": "next round"},
      {"id": "e20", "source": "socratic-questioner-1", "target": "analyst-1", "type": "feedback", "label": "deepen analysis"},
      {"id": "e21", "source": "steel-manner-2", "target": "strategist-2", "type": "feedback", "label": "refine position"},
      {"id": "e22", "source": "troll-3", "target": "devils-advocate-3", "type": "feedback", "label": "strengthen challenge"},
      {"id": "e23", "source": "synthesizer-4", "target": "mediator-4", "type": "feedback", "label": "re-integrate"},
      {"id": "e24", "source": "optimizer-5", "target": "moderator-5", "type": "feedback", "label": "polish closure"}
    ],
    "entry_point": "input-1",
    "termination_conditions": [
      {"type": "max_rounds", "value": "{{max_rounds}}", "description": "Maximum debate rounds"},
      {"type": "consensus_reached", "value": 0.9, "description": "Consensus threshold"}
    ]
  },
  "placeholders": [
