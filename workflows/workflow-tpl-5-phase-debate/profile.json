    "edges": [
      {"id": "e1", "source": "input-1", "target": "init-1", "type": "sequential"},
      {"id": "e2", "source": "init-1", "target": "analyst-1", "type": "sequential"},
      {"id": "e3", "source": "analyst-1", "target": "creative-thinker-1", "type": "sequential"},
