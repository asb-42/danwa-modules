    {"key": "moderator_blueprint_id", "type": "blueprint_ref", "description": "Agent Blueprint for the Moderator role (Phase 5)"},
    {"key": "critic_blueprint_id", "type": "blueprint_ref", "description": "Agent Blueprint for the Critic role (Phase 5)"},
    {"key": "optimizer_blueprint_id", "type": "blueprint_ref", "description": "Agent Blueprint for the Optimizer role (Phase 5)"},
