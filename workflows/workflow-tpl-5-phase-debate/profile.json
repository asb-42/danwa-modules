      {"id": "socratic-questioner-1", "type": "wf-socratic-questioner", "label": "Socratic Questioner", "phase": 1, "agent_blueprint_id": "{{socratic_questioner_blueprint_id}}", "position": {"x": 550, "y": 450}},
      {"id": "strategist-2", "type": "wf-strategist", "label": "Strategist", "phase": 2, "agent_blueprint_id": "{{strategist_blueprint_id}}", "position": {"x": 850, "y": 150}},
      {"id": "expert-reviewer-2", "type": "wf-expert-reviewer", "label": "Expert Reviewer", "phase": 2, "agent_blueprint_id": "{{expert_reviewer_blueprint_id}}", "position": {"x": 850, "y": 300}},
      {"id": "steel-manner-2", "type": "wf-steel-manner", "label": "Steel Manner", "phase": 2, "agent_blueprint_id": "{{steel_manner_blueprint_id}}", "position": {"x": 850, "y": 450}},
      {"id": "devils-advocate-3", "type": "wf-devils-advocate", "label": "Devil's Advocate", "phase": 3, "agent_blueprint_id": "{{devils_advocate_blueprint_id}}", "position": {"x": 1150, "y": 150}},
      {"id": "fact-checker-3", "type": "wf-fact-checker", "label": "Fact Checker", "phase": 3, "agent_blueprint_id": "{{fact_checker_blueprint_id}}", "position": {"x": 1150, "y": 300}},
      {"id": "troll-3", "type": "wf-troll", "label": "Troll", "phase": 3, "agent_blueprint_id": "{{troll_blueprint_id}}", "position": {"x": 1150, "y": 450}},
      {"id": "mediator-4", "type": "wf-mediator", "label": "Mediator", "phase": 4, "agent_blueprint_id": "{{mediator_blueprint_id}}", "position": {"x": 1450, "y": 150}},
      {"id": "ethicist-4", "type": "wf-ethicist", "label": "Ethicist", "phase": 4, "agent_blueprint_id": "{{ethicist_blueprint_id}}", "position": {"x": 1450, "y": 300}},
      {"id": "synthesizer-4", "type": "wf-synthesizer", "label": "Synthesizer", "phase": 4, "agent_blueprint_id": "{{synthesizer_blueprint_id}}", "position": {"x": 1450, "y": 450}},
      {"id": "moderator-5", "type": "wf-moderator", "label": "Moderator", "phase": 5, "agent_blueprint_id": "{{moderator_blueprint_id}}", "position": {"x": 1750, "y": 150}},
